{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": [
    "APP_SESSION_COOKIE_NAME",
    "APP_SESSION_SECRET",
    "BACKEND_URL",
    "VITE_PAYSTACK_PUBLIC_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    }
  }
}
