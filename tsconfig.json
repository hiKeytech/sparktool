{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "paths": { "@/*": ["./src/*"] },
    "incremental": true,
    "strictNullChecks": true,
    "strict": false,
    "noEmit": true,
    "allowJs": true
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts"],
  "exclude": ["node_modules"]
}
